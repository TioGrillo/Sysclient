{
  "name": "pokeidlebot-web",
  "version": "4.3.12",
  "description": "PokeIdleBot Web Version + React",
  "main": "dist/main/index.js",
  "author": {
    "name": "PokeIdleBot"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "build": "npx tsc -p tsconfig.main.json && npx tsc -p tsconfig.preload.json && npx vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "pack": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.0.0",
    "extract-zip": "^2.0.1",
    "framer-motion": "^12.0.0",
    "https-proxy-agent": "^9.1.0",
    "i18next": "^25.0.0",
    "lucide-react": "^0.500.0",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.0.0",
    "undici": "^8.8.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/extract-zip": "^1.6.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.pokeidlebot.web",
    "productName": "PokeIdleBot",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "TioGrillo",
        "repo": "Sysclient"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "package.json"
    ]
  }
}
